        <!-- PHASE 5: Ongoing Updates -->
        <mxCell id="phase5" value="PHASE 5: Ongoing Updates (Automated)" style="text;html=1;align=left;fontSize=12;fontStyle=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;rounded=1;spacingLeft=10;" vertex="1" parent="1">
