        <!-- PHASE 4: Subscription -->
        <mxCell id="phase4" value="PHASE 4: Consumer Subscription &amp; Access" style="text;html=1;align=left;fontSize=12;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;spacingLeft=10;" vertex="1" parent="1">
