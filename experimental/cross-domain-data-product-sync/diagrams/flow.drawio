        <mxCell id="s9" value="⑨ Consumer discovers&#xa;asset in catalog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="550" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="s10" value="⑩ Subscribe&#xa;(PENDING)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="550" width="120" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="s11" value="⑪ Approver approves&#xa;(manual — Federation project)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#8E24AA;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="545" width="210" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="s12" value="⑫ DataZone NATIVELY:&#xa;• Grants LF SELECT to consumer role&#xa;• Creates resource link in consumer DB&#xa;(No custom Lambda needed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="540" width="230" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="s13" value="⑬ Consumer QUERIES&#xa;&#xa;Athena / Notebook&#xa;→ resource link&#xa;→ mirrored table&#xa;→ LF credential vending&#xa;→ Account 1 S3 (zero copy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="535" width="220" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="s4-limits" value="⚠️ Limitations:&#xa;• Approval is in Account 2&#xa;  (not routed to Account 1 yet)&#xa;• Consumer sees resource link&#xa;  name (customer_accounts_1)&#xa;  not original table name" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1120" y="540" width="200" height="95" as="geometry" />
        </mxCell>
        
