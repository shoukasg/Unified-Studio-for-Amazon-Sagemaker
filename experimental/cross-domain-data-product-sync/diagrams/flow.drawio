        <mxCell id="s-revoke" value="Revoke subscription&#xa;→ DataZone removes LF&#xa;→ Consumer loses access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#8E24AA;fontSize=10;" vertex="1" parent="1">
