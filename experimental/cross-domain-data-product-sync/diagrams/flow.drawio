        <!-- PHASE 3: Data Source in Account 2 -->
        <mxCell id="phase3" value="PHASE 3: Data Source Run in Account 2 (THE KEY STEP)" style="text;html=1;align=left;fontSize=12;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="320" width="1760" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="s6-ds" value="⑥ Run Data Source&#xa;(Account 2 — MANUAL)&#xa;Federation Project" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="360" width="180" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="s6-managed" value="Data source discovers&#xa;mirrored table →&#xa;creates MANAGED asset&#xa;(sets DataSourceReferenceForm,&#xa;SubscriptionTermsForm)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="240" y="355" width="200" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="s6-event" value="Native EventBridge event&#xa;(instant)&#xa;&quot;Data Source Run Succeeded&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="470" y="360" width="150" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="s7-lambda" value="⑦ catalog-sync-mirror Lambda&#xa;1. Lists tables in Account 1&#xa;2. Finds managed asset (by catalogId+db+table)&#xa;3. Reads ALL existing forms from asset&#xa;4. Reads business metadata from Account 1&#xa;5. Merges summary+readme into forms&#xa;6. create_asset_revision (ALL forms)&#xa;7. Auto-publishes&#xa;8. Pulls DQ results → PostTimeSeriesDataPoints&#xa;9. Syncs lineage → PostLineageEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="345" width="280" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="s8-result" value="⑧ RESULT:&#xa;✓ Managed asset (subscribable)&#xa;✓ Business name from Account 1&#xa;✓ Description + Summary + Readme&#xa;✓ DQ results (pulled from Account 1)&#xa;✓ Lineage synced&#xa;✓ Published in catalog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=9;fontStyle=1;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="940" y="350" width="220" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="s6-limits" value="⚠️ Limitations:&#xa;• Data source run is manual&#xa;  (can schedule hourly)&#xa;• Glossary terms NOT synced&#xa;  (domain-scoped)&#xa;• Column descriptions only if&#xa;  present in Account 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1190" y="350" width="190" height="110" as="geometry" />
        </mxCell>
        
        <!-- Arrows Phase 3 -->
        <mxCell id="c1" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s6-ds" target="s6-managed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c2" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s6-managed" target="s6-event"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3" style="rounded=1;strokeWidth=2;strokeColor=#E53935;" edge="1" parent="1" source="s6-event" target="s7-lambda"><mxGeometry relative="1" as="geometry" /></mxCell>
