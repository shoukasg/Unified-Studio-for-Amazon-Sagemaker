        <!-- Title -->
        <mxCell id="title" value="Cross-Domain Data Product Lifecycle — Sequence Flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="500" y="10" width="500" height="30" as="geometry" />
        </mxCell>
        
        <!-- PHASE 1: Table Creation -->
        <mxCell id="phase1" value="PHASE 1: Table Creation &amp; Sync" style="text;html=1;align=left;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="50" width="1760" height="25" as="geometry" />
        </mxCell>
        
        <!-- Step 1 -->
        <mxCell id="s1-user" value="① User: CREATE TABLE&#xa;rooter_glue_db_981.customer_accounts&#xa;(Iceberg on S3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="90" width="220" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="s1-ct" value="CloudTrail-based event&#xa;(Glue has no native EB events&#xa;for table ops — ~30s delay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="280" y="90" width="140" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="s1-eb1" value="EventBridge (Acct 1)&#xa;glue-table-sync-to-account2&#xa;matches CreateTable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="430" y="90" width="170" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="s1-eb2" value="→ Cross-account →&#xa;EventBridge (Acct 2)&#xa;glue-sync-from-account1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="630" y="90" width="160" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="s1-lambda" value="glue-table-sync Lambda&#xa;1. Assumes GlueFederationAccessRole&#xa;2. Reads table from Account 1&#xa;3. Creates table in Account 2&#xa;4. Grants LF SELECT+DESCRIBE&#xa;   (with grant option) to project role" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="820" y="80" width="250" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="s1-result" value="RESULT:&#xa;✓ Mirrored table in Account 2&#xa;✓ Points to Account 1 S3&#xa;✓ LF grantable ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="85" width="180" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="s1-limit" value="⚠️ Limitation:&#xa;~30s latency&#xa;(CloudTrail)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1310" y="90" width="110" height="55" as="geometry" />
        </mxCell>
        
        <!-- Arrows Phase 1 -->
        <mxCell id="a1" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s1-user" target="s1-ct"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a2" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s1-ct" target="s1-eb1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a3" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s1-eb1" target="s1-eb2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a4" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s1-eb2" target="s1-lambda"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a5" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s1-lambda" target="s1-result"><mxGeometry relative="1" as="geometry" /></mxCell>
        
        <!-- PHASE 2: Curate & Publish -->
        <mxCell id="phase2" value="PHASE 2: Curate &amp; Publish in Account 1" style="text;html=1;align=left;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="190" width="1760" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="s2-ds" value="② Run Data Source&#xa;(Account 1)&#xa;discovers table → asset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="230" width="170" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="s3-curate" value="③ Curate Asset&#xa;name, description, readme,&#xa;column descriptions, glossary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="230" y="225" width="190" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="s4-publish" value="④ PUBLISH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#8E24AA;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="450" y="235" width="110" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="s4-eb" value="Native EventBridge event&#xa;(instant — no CloudTrail)&#xa;&quot;Asset Added To Catalog&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="590" y="225" width="200" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="s4-lambda" value="catalog-sync-mirror Lambda fires&#xa;→ Reads asset from Account 1 ✓&#xa;→ Searches for managed asset...&#xa;→ NOT FOUND (expected)&#xa;→ Logs: &quot;awaiting data source run&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#9E9E9E;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="820" y="220" width="230" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="s4-note" value="⚠️ First-time only:&#xa;Lambda can't sync yet.&#xa;Resolves in Phase 3." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1080" y="230" width="150" height="55" as="geometry" />
        </mxCell>
        
        <!-- Arrows Phase 2 -->
        <mxCell id="b1" style="rounded=1;strokeWidth=1;" edge="1" parent="1" source="s2-ds" target="s3-curate"><mxGeometry relative="1" as="geometry" /></mxCell>
