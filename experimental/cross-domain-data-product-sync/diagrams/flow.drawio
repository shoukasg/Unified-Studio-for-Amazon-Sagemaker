        <mxCell id="s-update-auto" value="AUTO: catalog-sync-mirror&#xa;fires → finds managed asset&#xa;→ updates revision&#xa;→ re-publishes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=9;" vertex="1" parent="1">
